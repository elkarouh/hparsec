#!/usr/bin/env py2nim
import time

N = 1000000

def is_prime(n: int) -> bool:
    flag = True
    for k in 2..int(n**0.5):
        if n % k == 0:
            flag = False
            break
    return flag

def count_primes(n: int) -> int:
    count = 0
    for k in 2..<n:
        if is_prime(k):
            count += 1

    return count

start = time.perf_counter()
print(f"Number of primes: {count_primes(N)}")
print(f"time elapsed: {time.perf_counter() - start}/s")
