###################################################################################################
class Cut(Exception):
    def __init__(self, token_stream):
        message = f"Failed at {token_stream.get_farthest_token()}"
        super().__init__(message)


class ParserMeta(type):
    def __add__(cls, other_klass):
        klass = sequence(cls, other_klass)
        other_klass = literal(other_klass) if type(other_klass) is str else other_klass
        if cls.__name__ == "Sequence_Parser":
            klass.parsers = cls.parsers + [other_klass]
        else:
            klass.parsers = [cls, other_klass]
        return klass

    __radd__ = __add__

    def __or__(cls, other_klass):
        klass = choice(cls, other_klass)
        other_klass = literal(other_klass) if type(other_klass) is str else other_klass
        if cls.__name__ == "Choice_Parser":
            klass.parsers = cls.parsers + [other_klass]
        else:
            klass.parsers = [cls, other_klass]
        return klass

    def __getitem__(cls, subscript):
        if G.DEBUG:
            print(f"{subscript=}")
        if isinstance(subscript, slice):
            return several_times_parser(cls, subscript.start, subscript.stop)
        elif subscript == 0:
            return several_times_parser(cls, None, None)
        else:
            raise Exception(f"Not allowed: {subscript}")

    def __mul__(cls, other):
        return several_times_parser(cls, other, other)


class Parser(metaclass=ParserMeta):
    def __init__(self, nodes) -> None:
        if type(nodes) is list:
            if nodes:
                self.node = nodes[0]
                self.nodes = nodes
            else:
                # traceback.print_stack()
                self.nodes = []
        else:
            self.node = nodes
            self.nodes = [nodes]
        if G.DEBUG:
            print(self.__class__.__name__, "Constructor->", self.nodes)


def forward(parser_name):  # create a class dynamically
    class Lazy_Parser(Parser):
        @apply_parsing_context
        def parse(cls, token_stream):
            g = calling_module_namespace()
            parser = g[parser_name]
            return parser.parse(token_stream)

    Lazy_Parser.name = parser_name
    Lazy_Parser.__name__ = parser_name
    return Lazy_Parser


fw = forward  # alias


class shift(Parser):
    @apply_parsing_context
    def parse(cls, token_stream):
        if token := token_stream.get_new_token():
            return cls(token), token_stream
        return False


class nothing(Parser):
    @apply_parsing_context
    def parse(cls, token_stream):
        return None, token_stream


class fail(Parser):
    @apply_parsing_context
    def parse(cls, token_stream):
        raise Cut(token_stream)


def filt(predicate, p):
    class Filter(Parser):
        @apply_parsing_context
        def parse(cls, token_stream):
            m = p.parse(token_stream)
            if m and predicate(m[0].node):
                m[0].__class__ = cls
                return m[0], m[1]
            else:
                return False

    return Filter


def fmap(func, p):
    class Fmap(Parser):
        @apply_parsing_context
        def parse(cls, token_stream):
            m = p.parse(token_stream)
            if not m:
                return False
            ast, token_stream = m
            ast.node = func(ast.node)
            # ast.nodes=func(ast.nodes)
            ast.__class__ = cls
            return ast, token_stream

    return Fmap


def choice(p1, p2):
    class Choice_Parser(Parser):
        @apply_parsing_context
        def parse(
            cls, token_stream, start_index=0
        ):  # the start_index is necessary for backtracking
            for p in cls.parsers[start_index:]:
                if m := p.parse(token_stream):
                    return m
            return False

    return Choice_Parser


def sequence(p1, p2):
    class Sequence_Parser(Parser):
        @classmethod
        def post_process(cls, combined_asts):
            asts = [ast for ast in combined_asts if ast is not None]
            asts = list(
                filter(None, asts)
            )  # None is returned by the ignore parser and needs removal
            if len(asts) == 1:
                asts = asts[0]
            return cls(asts)

        @classmethod
        def parse_sequence(cls, token_stream, parsers):
            """This function was made recursive to allow backtracking"""
            p = parsers[0]
            if p.__name__ == "Lazy_Parser":
                g = calling_module_namespace()
                p = g[p.name]
            if (
                p.__name__ == "Choice_Parser"
            ):  # a choice parser, we have to implement backtracking
                for i in range(
                    len(p.parsers)
                ):  # look at the alternatives in the choice parser
                    if not (m := p.parse(token_stream, i)):
                        continue  # backtrack
                    ast, token_stream = m
                    if not parsers[1:]:
                        return [ast], token_stream
                    if not (m := cls.parse_sequence(token_stream, parsers[1:])):
                        continue  # backtrack
                    asts, token_stream = m
                    return [ast] + asts, token_stream
                return False  # this will trigger backtrack in the caller
            else:
                if not (m := p.parse(token_stream)):
                    return False
                ast, token_stream = m
                if not parsers[1:]:
                    return [ast], token_stream
                if not (m := cls.parse_sequence(token_stream, parsers[1:])):
                    return False  # will trigger backtrack in the caller
                asts, token_stream = m
                return [ast] + asts, token_stream

        @apply_parsing_context
        def parse(cls, token_stream):
            if res := cls.parse_sequence(token_stream, cls.parsers):
                combined_asts, token_stream = res
                return cls.post_process(combined_asts), token_stream
            return False

    return Sequence_Parser


def several_times_parser(parser, min_times, max_times=None):
    class Several_Times(Parser):
        @apply_parsing_context
        def parse(cls, token_stream):
            nodes = []
            while m := parser.parse(token_stream):
                ast, token_stream = m
                nodes.append(ast)
                if max_times is not None and len(nodes) == max_times:
                    break
            if min_times is None:
                if len(nodes) == 0:
                    return None, token_stream
            else:
                if len(nodes) < min_times:
                    return False
            return cls(nodes), token_stream

    return Several_Times


def ignore(parser):
    "to be used in a sequence, returns None (to be filtered by the sequence), will not appear in the result"

    class ignore_parser(Parser):
        @apply_parsing_context
        def parse(cls, token_stream):
            if m := parser.parse(token_stream):
                return None, m[1]
            return False

    return ignore_parser


cut = nothing | fail


#############################################################################
def Input(string):
    gen = Tokenizer(string)
    next(gen)  # skip the encoding token
    return gen


def expect(ty, val):
    parser = fmap(
        lambda tok: tok.string,
        filt(lambda tok: tok.type == ty and tok.string == val, shift),
    )
    # parser.__name__=f'expect_{val}'
    return parser


def expect_type(ty):
    parser = fmap(lambda tok: tok.string, filt(lambda tok: tok.type == ty, shift))
    # parser.__name__=f'expect_{ty}'
    return parser


def literal(mylit):
    parser = fmap(
        lambda tok: tok.string,
        filt(lambda tok: tok.type == tkn.NAME and tok.string == mylit, shift),
    )
    parser.__name__ = f"Literal_{mylit}"
    return parser


def expect_re(regex):
    parser = fmap(
        lambda tok: tok.string, filt(lambda tok: re.match(regex, tok.string), shift)
    )
    return parser


###############################################################################
LPAREN = ignore(expect(tkn.OP, "("))
RPAREN = ignore(expect(tkn.OP, ")"))
LBRACE = ignore(expect(tkn.OP, "{"))
RBRACE = ignore(expect(tkn.OP, "}"))
LBRACKET = ignore(expect(tkn.OP, "["))
RBRACKET = ignore(expect(tkn.OP, "]"))
COMMA = ignore(expect(tkn.OP, ","))
SEMICOLON = ignore(expect(tkn.OP, ";"))
VBAR = ignore(expect(tkn.OP, "|"))
COLON = ignore(expect(tkn.OP, ":"))
EQUAL = ignore(expect(tkn.OP, "="))
PLUS = ignore(expect(tkn.OP, "+"))
MINUS = ignore(expect(tkn.OP, "-"))
MUL = STAR = ignore(expect(tkn.OP, "*"))
SSTAR = expect(tkn.OP, "*")  # no ignore !!!
DIV = SLASH = ignore(expect(tkn.OP, "/"))
AMPER = ignore(expect(tkn.OP, "&"))
LESS = ignore(expect(tkn.OP, "<"))
GREATER = ignore(expect(tkn.OP, ">"))
DOT = ignore(expect(tkn.OP, "."))
PERCENT = ignore(expect(tkn.OP, "%"))
EQEQUAL = ignore(expect(tkn.OP, "=="))
NOTEQUAL = ignore(expect(tkn.OP, "!="))
LESSEQUAL = ignore(expect(tkn.OP, "<="))
GREATEREQUAL = ignore(expect(tkn.OP, ">="))
TILDE = ignore(expect(tkn.OP, "~"))
CIRCUMFLEX = ignore(expect(tkn.OP, "^"))
LEFTSHIFT = ignore(expect(tkn.OP, "<<"))
RIGHTSHIFT = ignore(expect(tkn.OP, ">>"))
DOUBLESTAR = ignore(expect(tkn.OP, "**"))
PLUSEQUAL = ignore(expect(tkn.OP, "+="))
MINEQUAL = ignore(expect(tkn.OP, "-="))
STAREQUAL = ignore(expect(tkn.OP, "*="))
SLASHEQUAL = ignore(expect(tkn.OP, "/="))
PERCENTEQUAL = ignore(expect(tkn.OP, "%="))
AMPEREQUAL = ignore(expect(tkn.OP, "&="))
VBAREQUAL = ignore(expect(tkn.OP, "|="))
CIRCUMFLEXEQUAL = ignore(expect(tkn.OP, "^="))
LEFTSHIFTEQUAL = ignore(expect(tkn.OP, "<<="))
RIGHTSHIFTEQUAL = ignore(expect(tkn.OP, ">>="))
DOUBLESTAREQUAL = ignore(expect(tkn.OP, "**="))
DOUBLESLASH = ignore(expect(tkn.OP, "//"))
DOUBLESLASHEQUAL = ignore(expect(tkn.OP, "//="))
RARROW = ignore(expect(tkn.OP, "->"))
ELLIPSIS = ignore(expect(tkn.OP, "..."))
COLONEQUAL = ignore(expect(tkn.OP, ":="))
DOUBLEDOT = ignore(DOT + DOT)
IDENTIFIER = filt(str.isidentifier, expect_type(tkn.NAME))
# IDENTIFIER = expect_re(r"\w")
NUMBER = expect_re(tkn.Number)
STRING = expect_re(tkn.String)
INTEGER = filt(str.isdecimal, expect_type(tkn.NUMBER))
FLOAT = expect_re(tkn.Floatnumber)
DECIMAL = expect_re(tkn.Decnumber)
QUESTION_MARK = ignore(expect(tkn.ERRORTOKEN, "?"))


# THE AST methods
@method(IDENTIFIER)
def to_py(self):
    return self.node


@method(NUMBER)
def to_py(self):
    return self.node


@method(INTEGER)
def to_py(self):
    return self.node


@method(STRING)
def to_py(self):
    return self.node


@method(FLOAT)
def to_py(self):
    return self.node


@method(SSTAR)
def to_py(self):
    return self.node


