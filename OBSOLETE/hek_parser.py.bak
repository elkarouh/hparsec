# https://blog.koehntopp.info/2023/03/14/tracing-python.html
def args_to_str(*args):
    return ", ".join(map(str, args))


def kwargs_to_str(**kwargs):
    ret = ""
    for k, v in kwargs.items():
        ret += f"{k}={v},"
    return ret[:-1]


def logging(func):
    func.__indent__ = 0

    @wraps(func)
    def wrapper_logging(*args, **kwargs):
        func_indent = " " * func.__indent__
        func.__indent__ += 2
        func_name = func.__qualname__
        func_args = args_to_str(*args)
        func_kwargs = kwargs_to_str(**kwargs)
        print(f"{func_indent} -> Enter: {func_name}({func_args}", end="")
        if func_kwargs != "":
            print(f", {func_kwargs}", end="")
        print(")")
        result = func(*args, **kwargs)
        print(f"{func_indent} <- Leave: {func_name}({result})")
        return result

    return wrapper_logging


def calling_module_namespace():
    for stk in inspect.stack():
        mod = inspect.getmodule(stk[0])
        if mod is None:
            import __main__

            return vars(__main__)
        if mod.__name__ != __name__:  # we found the first calling module
            return vars(mod)
    return globals()


method = lambda KLASS: lambda f: setattr(
    KLASS, f.__name__, f
)  # DECORATOR TO ADD A METHOD TO A CLASS


def method(KLASS):
    "DECORATOR TO ADD A METHOD TO A CLASS"

    @wraps(KLASS)
    def wrapper(f):
        setattr(KLASS, f.__name__, f)

    # give a name to the assigned class !!!
    g = calling_module_namespace()
    for name in g:
        if g[name] == KLASS:
            if G.DEBUG:
                print(f"assigning {name} to {KLASS.__name__}")
            KLASS.__name__ = name
            break
    return wrapper


##################################################################################################
class G:
    DEBUG = False
    memos = {}


def apply_parsing_context(parse_function):
    # @logging
    # @snoop
    @wraps(parse_function)
    def wrapper(cls, token_stream, *args):
        pos_ante = token_stream.mark()  # remember the start position
        if (memo := G.memos.get(pos_ante, {})) is {}:
            memo = G.memos[pos_ante]  # this position was never seen before
        elif (key := (cls, *args)) in memo:  # cache hit
            print("======================================cache hit")
            m, end_pos = memo[key]
            token_stream.reset(end_pos)
            return m
        if m := parse_function(cls, token_stream, *args):
            memo[key] = m, token_stream.mark()
            return m
        token_stream.reset(pos_ante)  # we fail, so we reset the remembered position
        memo[key] = m, token_stream.mark()
        return m  # this is False

    return classmethod(wrapper)


tokenize_string = lambda s: tkn.tokenize(io.BytesIO(s.encode("utf-8")).readline)


class Tokenizer:
    """An enhanced tokenizer"""

    def __init__(self, s):
        self.tokengen = tkn.tokenize(io.BytesIO(s.encode("utf-8")).readline)
        self.tokens = []  # a list of 2-tuples (token, list_of_expected_but_failed_tokens)
        self.pos = 0  # points to the next token, pos-1 points to the current token

    def mark(self):
        return self.pos  # points to the next token!

    def reset(self, pos):
        self.pos = pos  # points to the next token!

    def get_new_token(self):
        if self.pos == len(self.tokens):
            self.tokens.append((next(self.tokengen), []))
        token = self.tokens[self.pos][0]
        self.pos += 1
        return token

    def peep_next_token(self):
        tok = self.get_new_token()
        self.pos -= 1
        return tok

    def get_current_token(self):
        return self.tokens[self.pos - 1][0]

    def get_text(self, pos):
        """return the text between given token position to current position"""
        return " ".join(tk[0].string for tk in self.tokens[pos - 1 : -1])

    def get_farthest_token(self):
        return self.tokens[-1]

    def set_failed_token(self, expected_token_as_string):
        # the current token is at position (self.pos-1)
        self.tokens[self.pos - 1][1].append(expected_token_as_string)

    def __iter__(self):
        return self

    def __next__(self):
        token = self.get_new_token()
        if token is not None:
            return token
        raise StopIteration()


